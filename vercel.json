{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": null,
    "installCommand": "composer install --no-dev --prefer-dist --optimize-autoloader && npm ci",
    "buildCommand": "composer run vercel-build",
    "functions": {
        "vercel.php": {
            "runtime": "vercel-php@0.8.0",
            "maxDuration": 10
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/robots.txt",
            "dest": "/public/robots.txt"
        },
        {
            "src": "/(.*)",
            "dest": "/vercel.php"
        }
    ]
}

{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "public",
  "functions": {
    "api/lambda.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "rewrites": [
    { "source": "/api/blob-upload", "destination": "/api/blob-upload.js" },
    { "source": "/(.*)", "destination": "/api/lambda.php" }
  ],
  "buildCommand": "CI='' npm run build && echo skip..."
}
